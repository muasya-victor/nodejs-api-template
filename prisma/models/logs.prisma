enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  CRITICAL
}


model Log {
  id        Int       @id @default(autoincrement())
  level     LogLevel  @default(INFO)
  /** action e.g., "USER_CREATED", "PAYMENT_PROCESSED" */
  action    String  
  message   String
  userId    Int?      
  metadata  Json?     
  ip        String?  
  userAgent String?   
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User?     @relation(fields: [userId], references: [id])
}

