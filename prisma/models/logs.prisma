enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  CRITICAL
}

model Log {
  id       String    @id @default(uuid())
  level     LogLevel  @default(INFO)
  action    String
  message   String
  userId    String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User?     @relation(fields: [userId], references: [id])
}